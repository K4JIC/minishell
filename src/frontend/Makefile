# Basic settings
NAME    := myprog
CC      := cc
CFLAGS  := -Wall -Wextra -Werror -MMD -MP
INCLUDES	:=	-Iincludes -I../libft

ifdef DEBUG
CFLAGS += -DDEBUG=1
endif

# Source directories (追加する場合はここに追記)
SRCDIRS := utils\
		   lexer\
		   test

# Collect source files and map them to objs/.../*.o preserving directory layout
SRC     := $(foreach dir,$(SRCDIRS),$(wildcard $(dir)/*.c))
OBJDIR  := objs
OBJS    := $(patsubst %.c,$(OBJDIR)/%.o,$(SRC))

# libft
LIBFT   := ../libft/libft.a

# Dependency files generated by -MMD
DEPS    := $(OBJS:.o=.d)

.PHONY: all run clean fclean re libft

all: $(NAME)

# Link objects + libft
$(NAME): $(LIBFT) $(OBJS)
	$(CC) $(INCLUDES) $(CFLAGS) $(OBJS) $(LIBFT) -o $@

# Build libft if needed (delegates to ../libft's Makefile)
$(LIBFT):
	$(MAKE) -C ../libft

# Compile rule: objs/path/to/file.o <- path/to/file.c
# (mkdir -p for target directory so nested dirs are created)
$(OBJDIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(INCLUDES) $(CFLAGS) -c $< -o $@

# Include auto-generated dependency files (no error if missing)
-include $(DEPS)

run:
	make DEBUG=1
	make clean
	./$(NAME)

clean:
	rm -rf $(OBJDIR)
	rm -f $(DEPS)

fclean: clean
	rm -f $(NAME)

re: fclean all
